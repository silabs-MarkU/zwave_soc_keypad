define:
- name: APP_PROPERTIES_CONFIG_FILE
  value: <application_properties_config.h>
- name: FILE_ID_APPLICATIONDATA
  value: '0x00000'
config_file:
- path: config/cc_config/DoorLockKeyPad.cc_config
  directory: cc_config
- path: config/sample_keys/sample_encrypt.key
  directory: sample_keys
- path: config/sample_keys/sample_sign.key
  directory: sample_keys
template_contribution:
- name: cli_command
  priority: 0
  value:
    name: battery_report
    handler: cli_battery_report
    help: Send battery report
- name: cli_command
  priority: 0
  value:
    name: enter_user_code
    handler: cli_enter_user_code
    help: Enter a user code
    argument:
    - type: string
      help: Current user code
- name: cli_command
  priority: 0
  value:
    name: set_new_user_code
    handler: cli_set_new_user_code
    help: Set a new user code
    argument:
    - type: string
      help: User code to be set
- name: cli_command
  priority: 0
  value:
    name: set_doorhandle_state
    handler: cli_set_doorhandle_state
    help: Set door handle state to locked (1) or unlocked (0)
    argument:
    - type: string
      help: activate or deactivate
- name: cli_command
  priority: 0
  value:
    name: get_doorhandle_state
    handler: cli_get_doorhandle_state
    help: Get door handle state
- name: cli_command
  priority: 0
  value:
    name: get_doorbolt_state
    handler: cli_get_doorbolt_state
    help: Get door bolt state
- name: cli_command
  priority: 0
  value:
    name: get_doorlatch_state
    handler: cli_get_doorlatch_state
    help: Get doorlatch state
provides:
- name: zwave_sample_application
- name: zwave_soc_door_lock_keypad
configuration:
- name: SHORT_BUTTON_PRESS_DURATION_MS
  value: (400)
- name: MEDIUM_BUTTON_PRESS_DURATION_MS
  value: (1500)
- name: ZAF_CONFIG_REQUEST_KEY_S0
  value: '1'
- name: ZAF_CONFIG_REQUEST_KEY_S2_ACCESS
  value: '1'
- name: ZAF_CONFIG_GENERIC_TYPE
  value: GENERIC_TYPE_ENTRY_CONTROL
- name: ZAF_CONFIG_SPECIFIC_TYPE
  value: SPECIFIC_TYPE_DOOR_LOCK
- name: ZAF_CONFIG_PRODUCT_ID
  value: '1'
- name: ZAF_CONFIG_USER_ICON_TYPE
  value: ICON_TYPE_GENERIC_DOOR_LOCK_KEYPAD
- name: ZAF_CONFIG_INSTALLER_ICON_TYPE
  value: ICON_TYPE_GENERIC_DOOR_LOCK_KEYPAD
- name: CC_DOOR_LOCK_HANDLE_1
  value: DOOR_INSIDE
- name: NVM3_DEFAULT_MAX_OBJECT_SIZE
  value: '1900'
- name: NVM3_DEFAULT_CACHE_SIZE
  value: '100'
- name: SL_BOARD_ENABLE_VCOM
  value: '1'
- name: configUSE_IDLE_HOOK
  value: '1'
- name: configTIMER_TASK_PRIORITY
  value: '55'
- condition:
  - device_series_2
  name: configMAX_SYSCALL_INTERRUPT_PRIORITY
  value: '16'
- condition:
  - device_series_2
  name: configKERNEL_INTERRUPT_PRIORITY
  value: '112'
- name: configTIMER_QUEUE_LENGTH
  value: '8'
- condition:
  - device_series_2
  - device_security_vault
  name: SL_PSA_ITS_USER_MAX_FILES
  value: '32'
- condition:
  - device_series_2
  - device_security_vault
  name: SL_PSA_KEY_USER_SLOT_COUNT
  value: '14'
- condition:
  - device_series_2
  name: SL_SLEEPTIMER_PERIPHERAL
  value: SL_SLEEPTIMER_PERIPHERAL_BURTC
- name: CC_ASSOCIATION_MAX_GROUPS_PER_ENDPOINT
  value: '1'
- name: CC_ASSOCIATION_MAX_NODES_IN_GROUP
  value: '5'
- name: ZAF_CONFIG_SECURE_ONLY
  value: '1'
- name: SL_PSA_ITS_SUPPORT_V1_DRIVER
  value: '1'
- name: SL_PSA_ITS_SUPPORT_V2_DRIVER
  value: '1'
- name: SL_PSA_ITS_SUPPORT_V3_DRIVER
  value: '1'
- name: ZAF_APP_NAME
  value: '"door_lock_keypad"'
- name: U3C_BUFFER_SIZE_CREDENTIAL_DATA
  value: '32'
- name: SL_IOSTREAM_USART_VCOM_CONVERT_BY_DEFAULT_LF_TO_CRLF
  value: '1'
- name: SL_IOSTREAM_USART_VCOM_RESTRICT_ENERGY_MODE_TO_ALLOW_RECEPTION
  value: '0'
- name: SL_IOSTREAM_EUSART_VCOM_CONVERT_BY_DEFAULT_LF_TO_CRLF
  value: '1'
- unless:
  - brd4204a
  name: SL_IOSTREAM_EUSART_VCOM_RESTRICT_ENERGY_MODE_TO_ALLOW_RECEPTION
  value: '0'
- name: SL_IOSTREAM_EUSART_INSTANCE_RESTRICT_ENERGY_MODE_TO_ALLOW_RECEPTION
  value: '0'
- name: SL_IOSTREAM_EUSART_VCOM_BAUDRATE
  value: '9600'
- unless:
  - brd4204a
  name: SL_IOSTREAM_EUSART_VCOM_ENABLE_HIGH_FREQUENCY
  value: '0'
- name: SL_CLOCK_MANAGER_WDOG0CLK_SOURCE
  value: CMU_WDOG0CLKCTRL_CLKSEL_LFRCO
- unless:
  - brd4204a
  name: SL_CLOCK_MANAGER_EUSART0CLK_SOURCE
  value: CMU_EUSART0CLKCTRL_CLKSEL_LFRCO
- condition:
  - brd4204a
  name: SL_CLOCK_MANAGER_EUSART0CLK_SOURCE
  value: CMU_EUSART0CLKCTRL_CLKSEL_EM01GRPCCLK
- condition:
  - brd4204a
  name: SL_IOSTREAM_EUSART_VCOM_ENABLE_HIGH_FREQUENCY
  value: '1'
- condition:
  - brd4204a
  name: SL_IOSTREAM_EUSART_VCOM_RESTRICT_ENERGY_MODE_TO_ALLOW_RECEPTION
  value: '1'
ui_hints:
  highlight:
  - path: README.md
    focus: true
post_build:
- path: zwave_soc_keypad.slpb
  profile: zwave_application

